Cell[BoxData[
 RowBox[{
  RowBox[{"main5", "[", "scale_", "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
     "WIDTH", ",", "\[IndentingNewLine]", "HEIGHT", ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Running", "=", "True"}], ",", "\[IndentingNewLine]", "window", 
      ",", "\[IndentingNewLine]", "surface", ",", "\[IndentingNewLine]", 
      "rects", ",", "rect", ",", "\[IndentingNewLine]", "event"}], 
     "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"WIDTH", "=", 
      RowBox[{"64", "*", "scale"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"HEIGHT", "=", 
      RowBox[{"32", "*", "scale"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"getm", "[", "m_", "]"}], ":=", 
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"rlen", ",", "clen", ",", "r", ",", "rectss", ",", "n"}], 
         "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"rlen", ",", "clen"}], "}"}], "=", 
          RowBox[{"Dimensions", "[", "m", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"r", "=", 
          RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Do", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"m", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", ",", "j"}], "]"}], "]"}], "==", "1"}], ",", 
               "\[IndentingNewLine]", 
               RowBox[{"AppendTo", "[", 
                RowBox[{"r", ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{"i", "-", "1"}], ")"}], "*", "scale"}], ",", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{"j", "-", "1"}], ")"}], "*", "scale"}], ",", 
                   "scale", ",", "scale"}], "}"}]}], "]"}]}], "]"}], 
             "\[IndentingNewLine]", ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "clen"}], "}"}]}], "]"}], 
           "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "rlen"}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"n", "=", 
          RowBox[{"Length", "[", "r", "]"}]}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"rectss", "=", 
          RowBox[{"UnmanageObject", "[", 
           RowBox[{"RawMemoryExport", "[", "\[IndentingNewLine]", 
            RowBox[{"r", ",", "\[IndentingNewLine]", 
             RowBox[{"SDLType", "[", "\"\<SDL_Rect\>\"", "]"}]}], "]"}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{"rectss", ",", "n"}], "}"}], "]"}]}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"===", "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"m", "=", 
      RowBox[{"RandomInteger", "[", 
       RowBox[{"1", ",", 
        RowBox[{"{", 
         RowBox[{"64", ",", "32"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"window", "=", 
      RowBox[{"SDLCreateWindow", "[", 
       RowBox[{"\"\<Random Walk\>\"", ",", "SDLWINDOWPOSCENTERED", ",", 
        "SDLWINDOWPOSCENTERED", ",", "WIDTH", ",", "HEIGHT", ",", 
        "SDLWINDOWRESIZABLE"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"surface", "=", 
      RowBox[{"SDLGetWindowSurface", "[", "window", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"event", "=", 
      RowBox[{"SDLEvent", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{"Running", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"SDLPollEvent", "[", "event", "]"}], "==", "1"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Switch", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"SDLEvent", "[", "event", "]"}], "[", "\"\<type\>\"", 
             "]"}], ",", "\[IndentingNewLine]", "SDLQUIT", ",", 
            RowBox[{"Running", "=", "False"}]}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"rects", ",", "n"}], "}"}], "=", 
