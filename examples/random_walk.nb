Cell[BoxData[
 RowBox[{
  RowBox[{"randomwalk", "[", 
   RowBox[{"n_", ",", "scale_", ",", 
    RowBox[{"delay_", ":", "0"}]}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"WIDTH", "=", "900"}], ",", "\[IndentingNewLine]", 
      RowBox[{"HEIGHT", "=", "600"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Running", "=", "True"}], ",", "\[IndentingNewLine]", "window", 
      ",", "\[IndentingNewLine]", "surface", ",", "\[IndentingNewLine]", 
      "rects", ",", "rect", ",", "\[IndentingNewLine]", "event", ",", 
      "\[IndentingNewLine]", "color", ",", "colors", ",", 
      "\[IndentingNewLine]", "Move"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Move", "[", 
       RowBox[{"col_", ",", "rect_"}], "]"}], ":=", 
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"vx", ",", "vy", ",", "v", ",", "colour"}], "}"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"colour", "=", 
           RowBox[{"FromDigits", "[", 
            RowBox[{"col", ",", "16"}], "]"}]}], ";"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"v", ":=", 
          RowBox[{"RandomChoice", "[", 
           RowBox[{"{", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", 
               RowBox[{"-", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"0", ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"{", 
              RowBox[{"1", ",", "0"}], "}"}]}], "\[IndentingNewLine]", "}"}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"vx", ",", "vy"}], "}"}], "=", "v"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"vx", ":=", 
            RowBox[{"v", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"vy", ":=", 
            RowBox[{"v", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "*)"}], 
         "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"Do", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"SDLRectUpdate", "[", 
             RowBox[{"rect", ",", "\"\<x\>\"", ",", "vx"}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"SDLRectUpdate", "[", 
             RowBox[{"rect", ",", "\"\<y\>\"", ",", "vy"}], "]"}], ";", 
            "\[IndentingNewLine]", "\[IndentingNewLine]", 
            RowBox[{"SDLFillRect", "[", 
             RowBox[{"surface", ",", "rect", ",", "color"}], "]"}]}], 
           "\[IndentingNewLine]", ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "scale"}], "}"}]}], "]"}], ";"}]}], 
       "\[IndentingNewLine]", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"===", "===", "===", "==="}], "*)"}], "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"PrintTemporary", "[", 
      RowBox[{"Style", "[", 
       RowBox[{
        RowBox[{"\"\<Usage \>\"", "<>", 
         RowBox[{"ToString", "[", "n", "]"}], 
         "<>", "\"\< <num-of-agents>\>\""}], ",", "Green"}], "]"}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"window", "=", 
      RowBox[{"SDLCreateWindow", "[", 
       RowBox[{"\"\<Random Walk\>\"", ",", "SDLWINDOWPOSCENTERED", ",", 
        "SDLWINDOWPOSCENTERED", ",", "WIDTH", ",", "HEIGHT", ",", 
        "SDLWINDOWRESIZABLE"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"surface", "=", 
      RowBox[{"SDLGetWindowSurface", "[", "window", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"rects", "=", 
      RowBox[{"UnmanageObject", "[", 
       RowBox[{"RawMemoryExport", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ConstantArray", "[", 
          RowBox[{
           RowBox[{"{", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"WIDTH", "/", "2"}], ",", 
             RowBox[{"HEIGHT", "/", "2"}], ",", "2", ",", "2"}], "}"}], ",", 
           "n"}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"SDLType", "[", "\"\<SDL_Rect\>\"", "]"}]}], "]"}], "]"}]}], 
     ";", "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"colors", "=", 
      RowBox[{"RandomInteger", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{
           RowBox[{"2", "^", "32"}], "-", "1"}]}], "}"}], ",", "n"}], "]"}]}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"event", "=", 
      RowBox[{"SDLEvent", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{"Running", ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"SDLPollEvent", "[", "event", "]"}], "==", "1"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Switch", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"SDLEvent", "[", "event", "]"}], "[", "\"\<type\>\"", 
             "]"}], ",", "\[IndentingNewLine]", "SDLQUIT", ",", 
            RowBox[{"Running", "=", "False"}]}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"color", "=", 
            RowBox[{"colors", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"rect", "=", 
            RowBox[{"SDLRectFromArray", "[", 
             RowBox[{"rects", ",", 
              RowBox[{"i", "-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"Move", "[", 
            RowBox[{"color", ",", "rect"}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Range", "[", "n", "]"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"SDLUpdateWindowSurface", "[", "window", "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"SDLDelay", "[", "delay", "]"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"SDLDestroyWindowSurface", "[", "window", "]"}], ";"}], "*)"}],
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"SDLFreeSurface", "[", "surface", "]"}], ";"}], "*)"}], 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"SDLDestroyWindow", "[", "window", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"SDLQuit", "[", "]"}], ";"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "]"}]}]], "Input",
